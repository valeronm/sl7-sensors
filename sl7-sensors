#!/bin/bash
# sl7-sensors — user-facing entry point for the SL7 sensor stack.
set -euo pipefail

LIB=/usr/lib/sl7-sensors
DEFAULT=/etc/default/sl7-sensor-proxy

usage() {
    cat <<'EOF'
usage: sl7-sensors <command>

  setup [windows-root]      extract the sensor configuration from this
                            machine's Windows partition (one-time, root)
  lux                       stream the ambient light sensor to the terminal
  color                     stream the color sensor (lux, CCT, chromaticity)
  mode controller|desktop   choose who drives auto-brightness: this
                            package's backlight controller, or the
                            desktop's own (GNOME/KDE) — root
  curve                     show the controller's learned lux->brightness
                            calibration curve
  status                    show services, mode and a current reading

See sl7-sensors(1) for details.
EOF
    exit "${1:-0}"
}

# unit_state <unit> <condition-skip-msg> [--user]: bare is-active output is
# poor ergonomics — "inactive" for both a stopped daemon and a missing unit,
# "failed" with no pointer.
unit_state() {
    local unit=$1 skip=$2 scope=${3:-} load st res cond
    load=$(systemctl $scope show "$unit.service" -p LoadState --value \
        2>/dev/null || true)
    if [ "$load" != "loaded" ]; then
        echo "not installed"
        return
    fi
    st=$(systemctl $scope show "$unit.service" -p ActiveState --value \
        2>/dev/null || true)
    case "$st" in
        failed)
            res=$(systemctl $scope show "$unit.service" -p Result --value \
                2>/dev/null || true)
            echo "FAILED: ${res:-unknown} (journalctl $scope -u $unit)" ;;
        inactive)
            cond=$(systemctl $scope show "$unit.service" -p ConditionResult \
                --value 2>/dev/null || true)
            if [ "$cond" = no ]; then
                echo "$skip"
            else
                echo "not running"
            fi ;;
        *)
            echo "${st:-unknown}" ;;
    esac
}

[ $# -ge 1 ] || usage 1 >&2
cmd=$1; shift
case "$cmd" in
    setup)
        exec "$LIB/setup" "$@" ;;
    lux)
        # no "$@": a stray argument would silently switch the data type
        # (read-sensor's positional arg — use it directly for other types)
        exec "$LIB/read-sensor" ;;
    color)
        exec "$LIB/read-sensor" color ;;
    mode)
        exec "$LIB/sensor-proxy" set-mode "$@" ;;
    curve)
        exec "$LIB/sensor-proxy" show-curve ;;
    status)
        skip="skipped — config not extracted (run 'sl7-sensors setup')"
        for unit in sl7-sensors sl7-sensor-proxy; do
            printf '%-18s %s\n' "$unit:" "$(unit_state "$unit" "$skip")"
        done
        # The resync watcher lives in the user manager: under sudo/root
        # there is none to ask, so point at the desktop user instead.
        if systemctl --user show-environment >/dev/null 2>&1; then
            resync=$(unit_state sl7-backlight-resync \
                "skipped — no backlight device" --user)
        else
            resync="per-user — check as your desktop user"
            resync="$resync (systemctl --user status sl7-backlight-resync)"
        fi
        printf '%-18s %s\n' "resync watcher:" "$resync"
        args=$(grep '^ARGS=' "$DEFAULT" 2>/dev/null | cut -d= -f2- || true)
        if [ "$args" = "--controller" ]; then
            printf '%-18s controller (this package drives the backlight)\n' \
                "mode:"
        else
            printf '%-18s desktop (GNOME/KDE consumes the sensor proxy)\n' \
                "mode:"
        fi
        if n=$("$LIB/sensor-proxy" show-curve --count 2>/dev/null); then
            printf '%-18s %s point(s)\n' "curve:" "$n"
        else
            printf '%-18s not calibrated\n' "curve:"
        fi
        prop() {
            busctl get-property net.hadess.SensorProxy \
                /net/hadess/SensorProxy net.hadess.SensorProxy "$1" \
                2>/dev/null | awk '{print $2}'
        }
        has=$(prop HasAmbientLight) || true
        lux=$(prop LightLevel) || true
        printf '%-18s %s\n' "sensor present:" "${has:-unknown}"
        printf '%-18s %s\n' "last lux:" "${lux:-n/a}"
        ;;
    -h|--help|help)
        usage ;;
    *)
        echo "sl7-sensors: unknown command: $cmd" >&2; usage 1 >&2 ;;
esac
