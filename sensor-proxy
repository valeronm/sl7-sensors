#!/usr/bin/python3
"""net.hadess.SensorProxy drop-in backed by the Qualcomm Sensor Core (SSC).

Owns the SensorProxy D-Bus name that GNOME's gsd-power consumes for
auto-brightness, and serves LightLevel from the ambient_light sensor on the
ADSP over QMI/QRTR. Replaces iio-sensor-proxy on machines where the sensors
live behind the SSC and no IIO device exists (Snapdragon X Elite laptops).

Claim semantics match iio-sensor-proxy: the QMI subscription to the DSP is
only active while at least one client holds ClaimLight(); claims are dropped
automatically when the claiming client leaves the bus.

Requires: the SSC registry populated at boot (sl7-sensors.service — run
'sl7-sensors setup' once) and root (the D-Bus policy shipped by
iio-sensor-proxy allows only root to own the name).

With --controller it instead drives /sys/class/backlight directly (see
/etc/default/sl7-sensor-proxy); disable GNOME's own auto-brightness first:
gsettings set org.gnome.settings-daemon.plugins.power ambient-enabled false
"""
import glob
import json
import math
import os
import socket
import struct
import sys
import threading

import gi
gi.require_version("Gio", "2.0")
gi.require_version("GLib", "2.0")
from gi.repository import Gio, GLib

AF_QIPCRTR = 42
SNS_SERVICE = 400
SNS_CLIENT_REQ = 0x20
SNS_CLIENT_REPORT_IND = 0x21
SNS_CLIENT_JUMBO_IND = 0x22
SUID_LOOKUP = (0xABABABABABABABAB, 0xABABABABABABABAB)
SNS_SUID_MSGID_REQ = 512
SNS_SUID_MSGID_EVENT = 768
MSGID_STREAM_CONFIG = 513
MSGID_SENSOR_EVENT = 1025

# Preferred sources, in order. The surface color sensor reports FRACTIONAL
# lux (its first data field), while ambient_light rounds to integer lux —
# in dim rooms that quantization is a huge relative jitter. Both deliver
# at a fixed ~1.33 Hz whatever rate is requested (measured); the 4.0 is
# only a ceiling, accepted up to 4, refused above.
SENSOR_SOURCES = [("color", 4.0), ("ambient_light", 1.0)]

# gsd-power's own controller is too twitchy for a laptop: a 1.6 s EWMA and a
# linear lux->brightness map make the screen chase every passing shadow
# (measured: a 4-lux wiggle = 15% backlight swing). So we pre-smooth the lux
# we publish on D-Bus (gsd only uses RATIOS of LightLevel — it re-anchors its
# norm whenever the user touches the brightness slider):
#   - slow EMA (TAU_SLOW) so ambient drift moves brightness imperceptibly;
#   - a sustained large deviation (FAST_TRIGGER for FAST_HOLD_S) switches to
#     TAU_FAST so real lighting changes (lamp on/off) still respond quickly.
# D-Bus carries the smoothed value as TRUE lux; the gamma compression below is
# applied ONLY to the copy fed to our own --controller loop (see on_light).
TAU_SLOW = 6.0          # s
TAU_FAST = 1.5          # s
FAST_TRIGGER = 0.3      # relative deviation of raw vs EMA
FAST_HOLD_S = 1.5       # deviation must persist this long
# --controller response curve only: gamma compression flattens the map (light
# must change ~2.25x, not 1.5x, to traverse the anchor->100% range). No emit
# gating anywhere — gsd's EWMA is event-driven and time-weighted, so a dense
# stream of small steps ramps smoothly while sparse gated updates would land
# as visible jumps; rounding alone dedupes true steady state.
LUX_GAMMA = 0.5         # controller value = lux ** gamma
EMIT_ROUND = 2          # decimals of the controller (compressed) value

# --controller mode: drive /sys/class/backlight directly instead of relying
# on gsd-power's auto-brightness (GNOME 50's controller is event-driven and
# dual-anchored — it turns smooth input into visible jumps; disable it with
#   gsettings set org.gnome.settings-daemon.plugins.power ambient-enabled false
# when using this mode). Control law: brightness = K * ema_lux ** LUX_GAMMA,
# where K is learned whenever the user sets brightness manually (slider,
# keys — any external write we did not make) and persisted across restarts.
CTRL_TICK_MS = 100          # ramp step interval
CTRL_APPROACH = 0.15        # close this fraction of the gap per tick
CTRL_RAMP_STEP = 0.02       # max fraction of full range per tick (~5 s 0-100%)
CTRL_STOP_COUNTS = 2        # done when within this many raw counts of target
CTRL_ADOPT_FRAC = 0.015     # external change bigger than this = user intent
CTRL_MIN_FRAC = 0.02        # never go fully dark
CTRL_USER_POLL_S = 1.0      # how often to look for external writes
# Degenerate-input floor: below ~1 lux (compressed = lux**gamma), sensor data
# carries no usable signal — near-zero noise would swing k and the target
# wildly (observed with a stuck sensor: every slider correction re-anchored
# against garbage, then the next wiggle yanked brightness away again).
# Clamping the value used for anchoring AND targeting makes true darkness —
# and a dead sensor — behave as plain manual control at the anchored level.
CTRL_COMP_FLOOR = 1.0       # compressed-domain floor (== 1 lux at gamma 0.5)
# Calibration is a monotone multi-point curve [[comp, frac], ...] instead of
# a single anchor: corrections are local in log-light, so a night fix cannot
# re-tune daylight. A correction scales the curve with a linear falloff in
# ln(comp) distance (comp = lux**gamma halves ln-lux distances, so R=2.0
# means influence reaches exactly zero at e**4 ≈ 55x lux; 100x = 2.30 > R).
CTRL_WARP_RADIUS_LN = 2.0
CTRL_MERGE_EPS_LN = 0.1     # corrections within ~1.22x lux replace a point
                            # instead of stacking next to it (EMA jitter band)
CTRL_MAX_POINTS = 8         # the whole comp domain spans ~4.2 ln units
# Deferred anchoring: a correction freezes the target at the user's choice
# immediately, but is paired with the light level only once the EMA settles —
# anchoring against a still-falling reading decays the correction (observed:
# every slider fix in a darkening room kept sliding back down). Counters are
# _poll_user ticks (1 s), not wall clock, so the machine stays unit-testable.
CTRL_SETTLE_REL = 0.05      # comp move per poll below this = stable
CTRL_SETTLE_POLLS = 5       # consecutive stable polls before committing
CTRL_SETTLE_MAX_POLLS = 20  # flickering light must not defer forever
# The resync watcher calls SetBacklight mid-ramp, and mutter echoes that
# value back into sysfs up to ~a second stale. Any value we ourselves
# wrote within this many ticks is recognized as our own (re-adopted, keep
# ramping) instead of being read as user input. Short enough that a real
# key press rarely lands inside the ring; a repeat press always escapes.
CTRL_ECHO_TICKS = 30        # 3 s of write history at the 100 ms tick

BUS_NAME = "net.hadess.SensorProxy"
OBJ_PATH = "/net/hadess/SensorProxy"
IFACE = "net.hadess.SensorProxy"

