# ---------- minimal protobuf + QMI (see read-sensor for the annotated
# version; framing details in worklog 2026-07-20-sl7-als-bringup) ----------

def varint(n):
    out = b""
    while True:
        b = n & 0x7F
        n >>= 7
        out += bytes([b | (0x80 if n else 0)])
        if not n:
            return out


def tag(field, wire):
    return varint(field << 3 | wire)


def pb_bytes(field, data):
    return tag(field, 2) + varint(len(data)) + data


def pb_varint(field, val):
    return tag(field, 0) + varint(val)


def pb_fixed32(field, val):
    return tag(field, 5) + struct.pack("<I", val)


def pb_fixed64(field, val):
    return tag(field, 1) + struct.pack("<Q", val)


def read_varint(buf, i):
    val = shift = 0
    while i < len(buf):
        b = buf[i]
        i += 1
        val |= (b & 0x7F) << shift
        if not b & 0x80:
            return val, i
        shift += 7
    return val, i


def pb_parse(buf):
    out, i = {}, 0
    while i < len(buf):
        t, i = read_varint(buf, i)
        f, w = t >> 3, t & 7
        if w == 0:
            v, i = read_varint(buf, i)
        elif w == 1:
            v, i = buf[i:i + 8], i + 8
        elif w == 2:
            ln, i = read_varint(buf, i)
            v, i = buf[i:i + ln], i + ln
        elif w == 5:
            v, i = buf[i:i + 4], i + 4
        else:
            break
        out.setdefault(f, []).append(v)
    return out


def qmi_encode(msg_id, txn, payload):
    val = struct.pack("<H", len(payload)) + payload
    body = b"\x01" + struct.pack("<H", len(val)) + val
    return struct.pack("<BHHH", 0, txn, msg_id, len(body)) + body


def qmi_decode(buf):
    if len(buf) < 7:
        return None, None, None, {}
    mtype, txn, msg_id, _ = struct.unpack_from("<BHHH", buf, 0)
    tlvs, i = {}, 7
    while i + 3 <= len(buf):
        t, ln = buf[i], struct.unpack_from("<H", buf, i + 1)[0]
        tlvs[t] = buf[i + 3:i + 3 + ln]
        i += 3 + ln
    return mtype, txn, msg_id, tlvs


def client_request(suid, msg_id, payload=b""):
    suid_msg = pb_fixed64(1, suid[0]) + pb_fixed64(2, suid[1])
    susp = pb_varint(1, 1) + pb_varint(2, 0)
    req = pb_bytes(2, payload) if payload else b""
    return (pb_bytes(1, suid_msg) + pb_fixed32(2, msg_id) +
            pb_bytes(3, susp) + pb_bytes(4, req))


def qmi_events(tlvs):
    for e in pb_parse(tlvs[2][2:]).get(2, []):
        inner = pb_parse(e)
        if 1 not in inner:
            continue
        eid = struct.unpack("<I", inner[1][0])[0]
        yield eid, inner[3][0] if 3 in inner else b""


def find_service():
    s = socket.socket(AF_QIPCRTR, socket.SOCK_DGRAM, 0)
    s.settimeout(2.0)
    s.sendto(struct.pack("<5I", 10, 0, 0, 0, 0), (1, 0xFFFFFFFE))
    found = None
    while True:
        try:
            data, _ = s.recvfrom(4096)
        except socket.timeout:
            break
        if len(data) >= 20:
            cmd, svc, _, node, port = struct.unpack_from("<5I", data, 0)
            if cmd == 4 and svc == SNS_SERVICE:
                found = (node, port)
    s.close()
    return found


def lookup_suid(addr, data_type):
    sock = socket.socket(AF_QIPCRTR, socket.SOCK_DGRAM, 0)
    sock.settimeout(3.0)
    try:
        req = client_request(SUID_LOOKUP, SNS_SUID_MSGID_REQ,
                             pb_bytes(1, data_type.encode()) + pb_varint(2, 0))
        sock.sendto(qmi_encode(SNS_CLIENT_REQ, 1, req), addr)
        deadline = GLib.get_monotonic_time() + 6_000_000
        while GLib.get_monotonic_time() < deadline:
            try:
                data, _ = sock.recvfrom(65536)
            except socket.timeout:
                return None
            _, _, mid, tlvs = qmi_decode(data)
            if mid not in (SNS_CLIENT_REPORT_IND, SNS_CLIENT_JUMBO_IND) \
                    or 2 not in tlvs:
                continue
            for eid, pay in qmi_events(tlvs):
                if eid != SNS_SUID_MSGID_EVENT:
                    continue
                for sb in pb_parse(pay).get(2, []):
                    su = pb_parse(sb)
                    return (struct.unpack("<Q", su[1][0])[0],
                            struct.unpack("<Q", su[2][0])[0])
        return None
    finally:
        sock.close()


def curve_valid(pts):
    """Validate a stored curve: a corrupt state file must not poison the
    controller (mirrors the old anchor paranoia)."""
    if not isinstance(pts, list) or not 0 < len(pts) <= 64:
        return False
    prev = 0.0
    for p in pts:
        if not isinstance(p, list) or len(p) != 2:
            return False
        x, y = p
        for v in (x, y):
            if isinstance(v, bool) or not isinstance(v, (int, float)):
                return False
        # NaN needs no explicit test: it fails the range checks below
        if not (CTRL_COMP_FLOOR <= x <= 1e6) or x <= prev or not 0 < y <= 1:
            return False
        prev = x
    return True


def state_curve(state):
    """Normalize a loaded state file to curve points, or None.

    The one place that understands both formats: the current
    {"curve": ...} and the legacy single-anchor {"k": ...}, which maps to
    a one-point curve (the below-first-point origin ray IS k*comp). k > 1
    is clamped: the old law already saturated the target at 1.0 there.
    """
    if not isinstance(state, dict):
        return None
    if curve_valid(state.get("curve")):
        return [[float(x), float(y)] for x, y in state["curve"]]
    k = state.get("k")
    if not isinstance(k, bool) and isinstance(k, (int, float)) \
            and 0 < k < 1e6:
        return [[1.0, min(float(k), 1.0)]]
    return None


def curve_target(points, comp):
    """Compressed light -> clamped brightness fraction: the one place the
    floor + eval + clamp pipeline lives (daemon targeting and the
    show-curve 'current' line must always agree)."""
    comp = max(comp, CTRL_COMP_FLOOR)
    return min(1.0, max(CTRL_MIN_FRAC, curve_eval(points, comp)))


def find_backlight():
    """The backlight device and its range; the sorted-glob-first pick
    policy must stay matched with backlight-resync's copy (the watcher
    has to watch the device the controller drives)."""
    bl = sorted(glob.glob("/sys/class/backlight/*"))
    if not bl:
        return None, 0
    try:
        with open(os.path.join(bl[0], "max_brightness")) as f:
            return bl[0], int(f.read())
    except (OSError, ValueError):
        return bl[0], 0


def curve_eval(points, comp):
    """Raw curve value at comp; the caller clamps to [CTRL_MIN_FRAC, 1.0].

    Piecewise-linear between control points. Both ends extrapolate along
    the ray from the origin through the nearest point: below, that is
    exactly the classic k*comp law of a single anchor (migration is
    behavior-identical); above, continuing the last SEGMENT instead would
    let a shallow night-side segment cap daylight at night levels.
    """
    if comp <= points[0][0]:
        return comp * points[0][1] / points[0][0]
    if comp >= points[-1][0]:
        return comp * points[-1][1] / points[-1][0]
    for (x0, y0), (x1, y1) in zip(points, points[1:]):
        if comp <= x1:
            return y0 + (y1 - y0) * (comp - x0) / (x1 - x0)


def curve_warp(points, comp_c, frac_c):
    """Fold a user correction (comp_c -> frac_c) into the curve.

    Short-term-model style (AOSP): scale the curve by the correction
    factor with a linear falloff in ln(comp) distance, then insert the
    exact point. Multiplicative, not additive — fractions span two
    decades, and an additive night offset would double daylight while a
    scale factor decays to a few percent. Monotonicity is repaired by
    clamping neighbors to the inserted point (a correction that
    contradicts a neighbor is the user's own statement about that
    region); dropping them instead would hand the region to the origin-ray
    extrapolation, which overshoots.
    """
    lc = math.log(comp_c)
    factor = frac_c / max(curve_eval(points, comp_c), 1e-6)
    factor = min(50.0, max(1 / 50.0, factor))
    warped = []
    for x, y in points:
        d = abs(math.log(x) - lc)
        if d < CTRL_MERGE_EPS_LN:       # merged into the new point
            continue
        w = max(0.0, 1.0 - d / CTRL_WARP_RADIUS_LN)
        warped.append([x, min(1.0, max(CTRL_MIN_FRAC, y * factor ** w))])
    new_pt = [comp_c, frac_c]           # tracked by identity below
    idx = 0
    while idx < len(warped) and warped[idx][0] < comp_c:
        idx += 1
    warped.insert(idx, new_pt)
    for i in range(idx - 1, -1, -1):
        warped[i][1] = min(warped[i][1], warped[i + 1][1])
    for i in range(idx + 1, len(warped)):
        warped[i][1] = max(warped[i][1], warped[i - 1][1])

    def deviation(i):
        (x0, y0), (x, y), (x1, y1) = warped[i - 1], warped[i], warped[i + 1]
        return abs(y - (y0 + (y1 - y0) * (x - x0) / (x1 - x0)))

    # drop interior points the interpolation already implies, then enforce
    # the budget by dropping whoever distorts the curve least
    i = 1
    while i < len(warped) - 1:
        if warped[i] is not new_pt and deviation(i) < 1e-4:
            warped.pop(i)
        else:
            i += 1
    while len(warped) > CTRL_MAX_POINTS:
        cands = [i for i in range(1, len(warped) - 1)
                 if warped[i] is not new_pt]
        if not cands:
            break
        warped.pop(min(cands, key=deviation))
    return warped


class BacklightController:
    """Owns the lux -> backlight loop when --controller is active."""

    def __init__(self, proxy):
        self.proxy = proxy
        self.enabled = False
        self.last_comp = None       # last compressed light value seen
        self.bl_path, self.bl_max = find_backlight()
        self.state_dir = os.environ.get("STATE_DIRECTORY",
                                        os.path.expanduser("~/.local/state"))
        self.state_file = os.path.join(self.state_dir, "anchor.json")
        self.curve = None           # calibration: [[comp, frac], ...]
        self.target = None          # fraction we're steering toward
        self.last_written = None    # raw value of our last write
        self.tick_seq = 0
        self.recent_writes = []     # (tick_seq, value): echo recognition
        self.pending = None         # correction awaiting settled light:
                                    # {frac, polls, stable, ref}
        self.writable = bool(self.bl_path) and os.access(
            os.path.join(self.bl_path, "brightness"), os.W_OK)
        self._load_state()

    def _read(self, attr):
        try:
            with open(os.path.join(self.bl_path, attr)) as f:
                return f.read().strip()
        except OSError:
            return None

    def _load_state(self):
        try:
            with open(self.state_file) as f:
                state = json.load(f)
        except (OSError, ValueError):
            # this runs in __init__; anything escaping restart-loops the
            # unit, and state_curve below rejects every wrong shape
            return
        curve = state_curve(state)
        if curve is None:
            return
        self.curve = curve
        if curve_valid(state.get("curve")):
            print(f"controller: curve loaded, {len(curve)} point(s)",
                  flush=True)
        else:
            self._save_state()          # persist: show-curve reads the file
            print(f"controller: anchor k={state['k']:.4f} migrated to "
                  "1-point curve", flush=True)

    def _save_state(self):
        try:
            os.makedirs(self.state_dir, exist_ok=True)
            with open(self.state_file, "w") as f:
                json.dump({"curve": self.curve}, f)
        except OSError as e:
            print(f"controller: state save failed: {e}", file=sys.stderr)

    def start(self):
        if not self.bl_path or not self.bl_max:
            print("controller: no backlight device, disabled", file=sys.stderr)
            return
        if not self.writable:
            print("controller: backlight not writable, DRY RUN", flush=True)
        self.enabled = True
        GLib.timeout_add(CTRL_TICK_MS, self._tick)
        GLib.timeout_add(int(CTRL_USER_POLL_S * 1000), self._poll_user)

    # Called on the main loop with the smoothed, gamma-compressed value.
    def on_light(self, compressed):
        compressed = max(compressed, CTRL_COMP_FLOOR)
        self.last_comp = compressed
        if self.curve is None:
            # First contact: adopt the current brightness for current light.
            cur = int(self._read("brightness") or 0)
            self.curve = [[compressed, max(cur / self.bl_max,
                                           CTRL_MIN_FRAC)]]
            self._save_state()
            print(f"controller: seeded curve at comp={compressed:.2f} -> "
                  f"{self.curve[0][1]:.0%}", flush=True)
        # A pending correction freezes the target at the user's choice;
        # retargeting resumes after the commit, which lands the curve on
        # exactly that value at the settled comp — no jump at unfreeze.
        if self.pending is None:
            self.target = curve_target(self.curve, compressed)

    def _record_write(self, val):
        """Every value we put into sysfs (ramp write or adopted user
        value) goes through here, so _is_own has one complete ledger."""
        self.last_written = val
        self.recent_writes.append((self.tick_seq, val))

    def _is_own(self, cur):
        """Is this sysfs value ours? The newest write matches at any age;
        older writes only within CTRL_ECHO_TICKS — long enough for
        mutter's ~1 s-stale echo of a resync-watcher SetBacklight, short
        enough that a real key press rarely collides."""
        if self.last_written is not None and abs(cur - self.last_written) <= 1:
            return True
        return any(abs(cur - v) <= 1 for _, v in self.recent_writes)

    def _tick(self):
        self.tick_seq += 1
        while self.recent_writes and \
                self.recent_writes[0][0] <= self.tick_seq - CTRL_ECHO_TICKS:
            self.recent_writes.pop(0)
        if self.target is None:
            return True
        cur = int(self._read("brightness") or 0)
        if self.last_written is not None and abs(cur - self.last_written) > 1:
            if self._is_own(cur):
                # mutter's echo of one of our recent writes (the watcher
                # syncing mid-ramp): re-adopt it and keep ramping
                self.last_written = cur
            else:
                # someone else moved the backlight (slider, keys, idle
                # dim): don't fight it — _poll_user will adopt it shortly
                return True
        # Exponential approach in raw counts: large gaps close fast (capped at
        # CTRL_RAMP_STEP/tick), small gaps glide in 1-count steps — the largest
        # possible visible increment is 1/4095, so drift can never look like a
        # jump. A hold-until-threshold deadband here would re-quantize smooth
        # drift into visible notches (measured: 60-count jumps once a second).
        delta_counts = self.target * self.bl_max - cur
        if abs(delta_counts) < CTRL_STOP_COUNTS:
            return True
        step = max(1.0, min(abs(delta_counts) * CTRL_APPROACH,
                            CTRL_RAMP_STEP * self.bl_max))
        val = cur + int(round(step)) * (1 if delta_counts > 0 else -1)
        if val != cur:
            if self.writable:
                try:
                    with open(os.path.join(self.bl_path, "brightness"), "w") as f:
                        f.write(str(val))
                except OSError as e:
                    print(f"controller: write failed: {e}", file=sys.stderr)
                    return True
            else:
                print(f"controller[dry]: {cur} -> {val}", flush=True)
            self._record_write(val)
        return True

    def _poll_user(self):
        """Adopt external brightness writes (slider/keys) as calibration.

        Deferred: the write freezes the target at the user's choice right
        away, but the curve is warped only once the light reading settles
        (or the poll cap runs out) — see the CTRL_SETTLE_* rationale. A
        further slider move while pending simply re-enters the detection
        below (it is > CTRL_ADOPT_FRAC from the frozen target) and updates
        the pending value with fresh counters.
        """
        if self.pending is not None:
            self._pending_tick()
        if self.target is None:
            return True
        cur = int(self._read("brightness") or 0)
        cur_frac = cur / self.bl_max
        # Mid-ramp our own writes differ from target; only treat values that
        # are neither our own (last write or a recent one echoed back by
        # mutter) nor within the deadband of the target as a user decision.
        if self._is_own(cur):
            return True
        if abs(cur_frac - self.target) < CTRL_ADOPT_FRAC:
            return True
        # A write to 0 is the screen blanking (DPMS/lock), not a brightness
        # choice — anchoring on it would slam the curve to the floor. Real
        # "as dark as possible" intent still lands: the slider's minimum is
        # above 0.
        if cur == 0:
            return True
        self.pending = {"frac": cur_frac, "polls": 0, "stable": 0,
                        "ref": self.last_comp}
        self.target = cur_frac
        self._record_write(cur)     # ours now: a late echo of it must not
                                    # re-enter adoption as fresh user input
        print(f"controller: user set {cur_frac:.0%}, waiting for light "
              "to settle", flush=True)
        return True

    def _pending_tick(self):
        p = self.pending
        p["polls"] += 1
        comp = self.last_comp
        if abs(comp - p["ref"]) <= CTRL_SETTLE_REL * p["ref"]:
            p["stable"] += 1
        else:
            p["stable"] = 0
            p["ref"] = comp
        if (p["stable"] >= CTRL_SETTLE_POLLS
                or p["polls"] >= CTRL_SETTLE_MAX_POLLS):
            self._commit_pending()

    def _commit_pending(self):
        # on_light always precedes a pending (nothing adopts before target
        # exists), so curve is seeded and last_comp >= CTRL_COMP_FLOOR here
        frac = min(1.0, max(self.pending["frac"], CTRL_MIN_FRAC))
        self.curve = curve_warp(self.curve, self.last_comp, frac)
        self._save_state()
        print(f"controller: user set {frac:.0%} at "
              f"comp={self.last_comp:.2f} (~{self.last_comp ** 2:.0f} "
              f"lux) — curve now {len(self.curve)} point(s)", flush=True)
        self.pending = None


class SensorProxy:
    def __init__(self):
        self.conn = None
        self.reg_id = None
        self.addr = None
        self.suid = None
        self.has_light = False
        self.light_level = 0.0
        self.rate_hz = 1.0
        self.controller = None
        self.claimers = {}          # sender -> (refcount, name watch id)
        self.stream_stop = None
        self.stream_thread = None
        self.logind = None
        self.sleep_inhibitor = None

    # --- D-Bus plumbing ---

    def start(self, bus_type=Gio.BusType.SYSTEM):
        Gio.bus_own_name(bus_type, BUS_NAME,
                         Gio.BusNameOwnerFlags.NONE,
                         self.on_bus_acquired, None, self.on_name_lost)

    def on_bus_acquired(self, conn, name):
        self.conn = conn
        node = Gio.DBusNodeInfo.new_for_xml(INTROSPECTION)
        self.reg_id = conn.register_object(
            OBJ_PATH, node.interfaces[0],
            self.on_method_call, self.on_get_property, None)
        self.setup_sleep_handling()
        threading.Thread(target=self.wait_for_sensor, daemon=True).start()

    def on_name_lost(self, conn, name):
        # Exit 5: matched by RestartPreventExitStatus in the unit so we don't
        # restart-loop against another SensorProxy owning the name.
        print(f"lost bus name {name} — is another sensor proxy running?",
              file=sys.stderr)
        sys.exit(5)

    def on_get_property(self, conn, sender, path, iface, prop):
        vals = {
            "HasAccelerometer": GLib.Variant("b", False),
            "AccelerometerOrientation": GLib.Variant("s", "undefined"),
            "HasAmbientLight": GLib.Variant("b", self.has_light),
            "LightLevelUnit": GLib.Variant("s", "lux"),
            "LightLevel": GLib.Variant("d", self.light_level),
            "HasProximity": GLib.Variant("b", False),
            "ProximityNear": GLib.Variant("b", False),
        }
        return vals.get(prop)

    def emit_changed(self, props):
        self.conn.emit_signal(
            None, OBJ_PATH, "org.freedesktop.DBus.Properties",
            "PropertiesChanged",
            GLib.Variant("(sa{sv}as)", (IFACE, props, [])))

    def on_method_call(self, conn, sender, path, iface, method, params,
                       invocation):
        if method == "ClaimLight":
            self.claim(sender)
        elif method == "ReleaseLight":
            self.release(sender)
        # Accelerometer/Proximity claims are accepted as no-ops: we report
        # Has*=False, but gsd should not error out if it calls them anyway.
        invocation.return_value(None)

    # --- claim tracking (main-loop thread only) ---

    def claim(self, sender):
        if sender in self.claimers:
            refs, watch = self.claimers[sender]
            self.claimers[sender] = (refs + 1, watch)
            return
        watch = Gio.bus_watch_name_on_connection(
            self.conn, sender, Gio.BusNameWatcherFlags.NONE,
            None, self.on_claimer_vanished)
        self.claimers[sender] = (1, watch)
        print(f"light claimed by {sender} ({len(self.claimers)} claimer(s))",
              flush=True)
        if len(self.claimers) == 1:
            self.start_stream()

    def release(self, sender):
        if sender not in self.claimers:
            return
        refs, watch = self.claimers[sender]
        if refs > 1:
            self.claimers[sender] = (refs - 1, watch)
            return
        self.drop_claimer(sender, watch)

    def on_claimer_vanished(self, conn, sender):
        # Client left the bus entirely: drop it regardless of refcount.
        if sender in self.claimers:
            _, watch = self.claimers[sender]
            self.drop_claimer(sender, watch)

    def drop_claimer(self, sender, watch):
        Gio.bus_unwatch_name(watch)
        del self.claimers[sender]
        print(f"light released by {sender} ({len(self.claimers)} claimer(s))",
              flush=True)
        if not self.claimers:
            self.stop_stream()

    # --- sensor side ---

    def discover_sensor(self):
        """find_service(), then pick the first available SENSOR_SOURCE.

        Returns (name, addr, suid, rate_hz) on success, None if neither the
        QMI service nor any configured sensor is present yet. Mutates no
        shared state: a lingering old stream thread re-discovering must not
        clobber the address a new thread is using.
        """
        addr = find_service()
        if not addr:
            return None
        for cand, rate in SENSOR_SOURCES:
            suid = lookup_suid(addr, cand)
            if suid:
                return cand, addr, suid, rate
        return None

    def wait_for_sensor(self):
        """Poll until the SSC registry is populated (sl7-sensors attach)."""
        name = None
        warned = False
        while not name:
            found = None
            try:
                found = self.discover_sensor()
            except Exception as e:
                # e.g. no AF_QIPCRTR support on this kernel, or a malformed
                # datagram mid-parse — keep serving HasAmbientLight=false
                # and retry rather than dying silently.
                if not warned:
                    print(f"sensor discovery failed ({e!r}); retrying",
                          file=sys.stderr)
                    warned = True
            if found:
                name, self.addr, self.suid, self.rate_hz = found
            else:
                threading.Event().wait(5)
        print(f"{name} found: suid={self.suid[0]:#x} {self.suid[1]:#x}, "
              f"{self.rate_hz:g} Hz", flush=True)
        GLib.idle_add(self.set_has_light)

    def set_has_light(self):
        self.has_light = True
        self.emit_changed({"HasAmbientLight": GLib.Variant("b", True)})
        # In controller mode the stream runs permanently; otherwise a client
        # may have claimed before the sensor appeared.
        if self.controller:
            self.start_stream()
            self.controller.start()
        elif self.claimers and not self.stream_thread:
            self.start_stream()
        return False

    def start_stream(self):
        if not self.suid or self.stream_thread:
            return
        self.stream_stop = threading.Event()
        self.stream_thread = threading.Thread(
            target=self.stream_loop, args=(self.stream_stop,), daemon=True)
        self.stream_thread.start()

    def stop_stream(self):
        if self.controller:      # controller consumes the stream permanently
            return
        if self.stream_stop:
            self.stream_stop.set()
        self.stream_thread = None
        self.stream_stop = None

    # --- suspend/resume (logind) ---
    # The ADSP has no idea the host is asleep: with a stream subscribed it
    # keeps pushing indications at rate_hz, and every one is an IPCC wakeup
    # interrupt that ends the suspend within one push interval. Hold a
    # logind delay inhibitor so the SSC session is closed BEFORE the system
    # sleeps, and resubscribe on resume. This must bypass the controller
    # guard in stop_stream() — suspend outranks the controller.

    def setup_sleep_handling(self):
        try:
            self.logind = Gio.bus_get_sync(Gio.BusType.SYSTEM, None)
            self.take_sleep_inhibitor()
            self.logind.signal_subscribe(
                "org.freedesktop.login1", "org.freedesktop.login1.Manager",
                "PrepareForSleep", "/org/freedesktop/login1", None,
                Gio.DBusSignalFlags.NONE, self.on_prepare_for_sleep, None)
        except Exception as e:
            # e.g. no logind (container/test session): stream just stays
            # subscribed across sleep, as before.
            print(f"logind sleep handling unavailable ({e!r})",
                  file=sys.stderr)

    def take_sleep_inhibitor(self):
        if self.logind is None or self.sleep_inhibitor is not None:
            return
        res, fds = self.logind.call_with_unix_fd_list_sync(
            "org.freedesktop.login1", "/org/freedesktop/login1",
            "org.freedesktop.login1.Manager", "Inhibit",
            GLib.Variant("(ssss)", ("sleep", "sl7-sensor-proxy",
                                    "closing the SSC sensor stream",
                                    "delay")),
            GLib.VariantType("(h)"), Gio.DBusCallFlags.NONE, -1, None, None)
        # The "(h)" reply carries a handle: an INDEX into the returned fd
        # list, not the fd itself. UnixFDList.get() dup()s it, so the fd we
        # store is ours to close — that close is what drops the inhibitor.
        self.sleep_inhibitor = fds.get(res.unpack()[0])

    def on_prepare_for_sleep(self, conn, sender, path, iface, signal,
                             params, data):
        entering = params.unpack()[0]
        if entering:
            self.suspend_stream()
            if self.sleep_inhibitor is not None:
                os.close(self.sleep_inhibitor)
                self.sleep_inhibitor = None
        else:
            try:
                self.take_sleep_inhibitor()
            except Exception as e:
                print(f"could not retake sleep inhibitor ({e!r})",
                      file=sys.stderr)
            if self.controller or self.claimers:
                self.start_stream()

    def suspend_stream(self):
        thread = self.stream_thread
        if self.stream_stop:
            self.stream_stop.set()
        self.stream_thread = None
        self.stream_stop = None
        if thread:
            # The stream thread lingers in recvfrom for up to 3 s; the
            # inhibitor's job is exactly to cover this join (logind's
            # default delay budget is 5 s). Socket close on thread exit is
            # what ends the SSC client session.
            thread.join(timeout=4.0)

    def stream_loop(self, stop):
        # All mutable state — filter state AND the QMI address/SUID — is
        # local to this thread: a stopped thread can linger in recvfrom for
        # up to 3 s while a new one starts, and they must not share it.
        addr, suid, rate = self.addr, self.suid, self.rate_hz
        ema = None
        fast_since = None
        sock = None
        while not stop.is_set():
            try:
                sock = socket.socket(AF_QIPCRTR, socket.SOCK_DGRAM, 0)
                sock.settimeout(3.0)
                cfg = tag(1, 5) + struct.pack("<f", rate)
                sock.sendto(qmi_encode(SNS_CLIENT_REQ, 2,
                                       client_request(suid,
                                                      MSGID_STREAM_CONFIG,
                                                      cfg)),
                            addr)
                idle = 0
                got_data = False
                while not stop.is_set():
                    try:
                        data, _ = sock.recvfrom(65536)
                    except socket.timeout:
                        idle += 1
                        if idle >= 5:       # 15 s silence: resubscribe
                            # QRTR drops sends to vanished ports silently, so
                            # a dead subscription raises nothing — re-discover
                            # rather than resubscribing to a stale address.
                            if not got_data:
                                found = self.discover_sensor()
                                if found:
                                    _, addr, suid, rate = found
                            break
                        continue
                    got_data = True
                    idle = 0
                    _, _, mid, tlvs = qmi_decode(data)
                    if mid not in (SNS_CLIENT_REPORT_IND,
                                   SNS_CLIENT_JUMBO_IND) or 2 not in tlvs:
                        continue
                    for eid, pay in qmi_events(tlvs):
                        if eid != MSGID_SENSOR_EVENT:
                            continue
                        body = pb_parse(pay)
                        for v in body.get(1, []):
                            if isinstance(v, bytes) and len(v) >= 4:
                                # clamp: a garbage negative would make
                                # ema**0.5 complex and crash the filter
                                lux = max(
                                    struct.unpack_from("<f", v, 0)[0], 0.0)
                                ema, fast_since = self.filter_sample(
                                    lux, ema, fast_since, rate)
                                break
                # Closing the socket ends the SSC client session.
                sock.close()
            except Exception as e:
                # ADSP restart / QRTR hiccup / malformed datagram: stale
                # address, dead socket, or a parse error. Re-discover the
                # service (and the sensor, in case its SUID changed) and
                # resubscribe rather than dying silently.
                print(f"sensor stream error ({e!r}); re-discovering",
                      file=sys.stderr)
                if sock is not None:
                    try:
                        sock.close()
                    except Exception:
                        pass
                stop.wait(5)
                try:
                    found = self.discover_sensor()
                    if found:
                        _, addr, suid, rate = found
                except Exception:
                    pass

    def filter_sample(self, lux, ema, fast_since, rate_hz):
        """Runs on the stream thread; returns updated (ema, fast_since)."""
        now = GLib.get_monotonic_time() / 1e6
        if ema is None:
            ema = lux
        else:
            deviation = abs(lux - ema) / max(ema, 1.0)
            if deviation > FAST_TRIGGER:
                if fast_since is None:
                    fast_since = now
            else:
                fast_since = None
            fast = fast_since is not None and now - fast_since >= FAST_HOLD_S
            tau = TAU_FAST if fast else TAU_SLOW
            dt = 1.0 / rate_hz
            ema += (dt / (tau + dt)) * (lux - ema)

        # D-Bus carries TRUE lux (the SensorProxy contract; KDE and scripts
        # read it as absolute). The gamma-compressed value is only for our
        # own controller's response curve.
        GLib.idle_add(self.update_light, round(ema, 1))
        if self.controller and self.controller.enabled:
            GLib.idle_add(self.controller.on_light,
                          round(ema ** LUX_GAMMA, EMIT_ROUND))
        return ema, fast_since

    def update_light(self, value):
        if value != self.light_level:
            self.light_level = value
            self.emit_changed({"LightLevel": GLib.Variant("d", value)})
        return False


DEFAULT_FILE = "/etc/default/sl7-sensor-proxy"


def set_mode(mode):
    """set-mode controller|desktop: edit /etc/default and restart the unit.

    Replaces the error-prone 'sed the conffile' dance. gsettings is per-user
    so the matching command is printed rather than run (we are root here).
    """
    import re
    import subprocess
    if mode not in ("controller", "desktop"):
        sys.exit("usage: sl7-sensors mode controller|desktop")
    if os.geteuid() != 0:
        sys.exit("sl7-sensors mode: error: must run as root "
                 "(edits /etc, restarts the unit)")
    args = "--controller" if mode == "controller" else ""
    try:
        with open(DEFAULT_FILE) as f:
            content = f.read()
    except OSError as e:
        sys.exit(f"sl7-sensors mode: error: cannot read {DEFAULT_FILE}: {e}")
    content, nsubs = re.subn(r"^ARGS=.*$", f"ARGS={args}", content, flags=re.M)
    if nsubs == 0:
        # ARGS line removed by hand — append rather than silently no-op
        content = content.rstrip("\n") + f"\nARGS={args}\n"
    try:
        with open(DEFAULT_FILE, "w") as f:
            f.write(content)
    except OSError as e:
        sys.exit(f"sl7-sensors mode: error: cannot write {DEFAULT_FILE}: {e}")
    subprocess.run(["systemctl", "restart", "sl7-sensor-proxy.service"],
                   check=True)
    print(f"mode: {mode} — service restarted.")
    if mode == "controller":
        print("Now disable GNOME's own auto-brightness (as your user):\n"
              "  gsettings set org.gnome.settings-daemon.plugins.power "
              "ambient-enabled false")
    else:
        print("Re-enable GNOME's auto-brightness (as your user):\n"
              "  gsettings set org.gnome.settings-daemon.plugins.power "
              "ambient-enabled true\n"
              "If brightness doesn't react, lock/unlock the screen "
              "(known gsd-power claim bug, see README).")


def show_curve(count_only=False):
    """show-curve: print the learned calibration (read-only, no root —
    the state file ships world-readable under the StateDirectory).
    --count prints just the point count: the machine mode 'status' reads,
    so the human table never becomes an interface."""
    state_dir = os.environ.get("STATE_DIRECTORY", "/var/lib/sl7-sensor-proxy")
    path = os.path.join(state_dir, "anchor.json")
    try:
        with open(path) as f:
            state = json.load(f)
    except FileNotFoundError:
        sys.exit("no calibration yet — the controller seeds it on first "
                 "light reading")
    except PermissionError:
        sys.exit(f"cannot read {path}; try sudo")
    except (OSError, ValueError) as e:
        sys.exit(f"cannot read {path}: {e}")
    pts = state_curve(state)            # legacy k renders as its 1-point curve
    if pts is None:
        sys.exit(f"unrecognized state in {path}")
    if count_only:
        print(len(pts))
        return
    print(f"{'lux':>8}  {'comp':>6}  brightness")
    for x, y in pts:
        print(f"{x * x:8.1f}  {x:6.2f}  {y:9.0%}")
    now = current_position(pts)
    if now:
        print(now)


def current_position(pts):
    """Best-effort 'you are here' line for show-curve: the proxy's current
    lux from the bus plus the actual backlight level. None when either
    side is unavailable (daemon down, no backlight) — the table alone is
    still useful then."""
    try:
        bus = Gio.bus_get_sync(Gio.BusType.SYSTEM, None)
        ret = bus.call_sync(BUS_NAME, OBJ_PATH,
                            "org.freedesktop.DBus.Properties", "Get",
                            GLib.Variant("(ss)", (IFACE, "LightLevel")),
                            GLib.VariantType("(v)"),
                            Gio.DBusCallFlags.NONE, 500, None)
        lux = float(ret.unpack()[0])
    except GLib.Error:
        return None
    bl_path, bl_max = find_backlight()
    if not bl_path or not bl_max:
        return None
    try:
        with open(os.path.join(bl_path, "brightness")) as f:
            cur = int(f.read())
    except (OSError, ValueError):
        return None
    # comp derived from the published (rounded) LightLevel: can differ
    # from the daemon's internal value by ~1% — inherent to reading over
    # the bus, fine for display
    comp = max(lux ** LUX_GAMMA, CTRL_COMP_FLOOR)
    target = curve_target(pts, comp)
    return (f"\ncurrent: {lux:.1f} lux (comp {comp:.2f}) -> curve "
            f"{target:.0%}, backlight {cur / bl_max:.0%}")


if __name__ == "__main__":
    if len(sys.argv) > 1 and sys.argv[1] == "set-mode":
        set_mode(sys.argv[2] if len(sys.argv) > 2 else "")
        sys.exit(0)
    if len(sys.argv) > 1 and sys.argv[1] == "show-curve":
        show_curve(count_only="--count" in sys.argv)
        sys.exit(0)
    # --session: own the name on the session bus instead — lets the full
    # claim/stream path be tested unprivileged (the system-bus policy only
    # allows root to own the name).
    # --controller: additionally drive the backlight directly (see above).
    bus = Gio.BusType.SESSION if "--session" in sys.argv else Gio.BusType.SYSTEM
    proxy = SensorProxy()
    if "--controller" in sys.argv:
        proxy.controller = BacklightController(proxy)
    proxy.start(bus)
    loop = GLib.MainLoop()
    loop.run()
